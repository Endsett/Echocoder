{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "../..",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "../../src/**/*.ts",
    "./*.test.ts"
  ],
  "exclude": [
    "../../src/ui/*.ts"
  ]
}
